# Supabase (voir §6 du cahier des charges) — Project Settings > Database
# DATABASE_URL : connection pooling (PgBouncer, port 6543) utilisée par l'appli
# DIRECT_URL   : connexion directe (port 5432) utilisée par `prisma migrate`
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-0-xxxxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:password@aws-0-xxxxx.pooler.supabase.com:5432/postgres"

# Auth.js — générer avec `npx auth secret` ou `openssl rand -base64 32`
AUTH_SECRET="changeme-generate-a-real-secret"

# Utilisées uniquement par `npx prisma db seed` pour créer le premier compte admin
ADMIN_EMAIL="admin@club.fr"
ADMIN_PSEUDO="admin"
ADMIN_NOM="Prénom Nom"
ADMIN_PASSWORD="changeme"
